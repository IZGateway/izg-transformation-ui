# Playwright e2e test configuration — copy to ".env.test" and fill in real values.
# ".env.test" is git-ignored. NEVER commit real credentials.

# Deployed Xform Console environment the tests run against.
# Defaults to https://dev.xform-ui.izgateway.org if unset (see playwright.config.ts).
BASE_URL=https://dev.xform-ui.izgateway.org

# Okta test account. Must be assigned to the Xform Okta application and belong
# to the Solutions-Engineer so /manage, /solutions and /mapping load.
OKTA_USERNAME=
OKTA_PASSWORD=

# Optional: the user's full name as shown in the app header after login. When
# set, the login test additionally asserts the header greets this user.
OKTA_EXPECTED_FULLNAME=

# Optional: slow each browser action by N ms (handy for local debugging).
SLOWMO=
