    "semver": "^7.8.5",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "glob": "^13.0.6",
    "js-yaml": "4.3.0",
    "jsdom": "^28.1.0",
    "postcss": "8.5.16",
    "swagger-jsdoc": "^6.3.0",
    "uuid": "npm:@izgateway/uuid-cjs@^14.0.7",
    "xmlbuilder2": "^4.0.3"
  }
}
