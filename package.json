{
  "name": "izg-transformation-console",
  "private": true,
  "version": "0.18.0",
  "scripts": {
    "dev": "next",
    "build": "next build",
    "start": "next start",
    "start:local-dev": "docker compose -f ./local-docker/docker-compose.yml up --build -d && npm run dev && docker compose -f ./local-docker/docker-compose.yml down",
    "start:local-docker": "docker compose up --build && docker compose down",
    "xform:compose:up": "docker compose -f ./docker-compose.local.yml up -d",
    "xform:compose:down": "docker compose -f ./docker-compose.local.yml down",
    "xform:compose:logs": "docker compose -f ./docker-compose.local.yml logs -f",
    "lint": "eslint .",
    "lint:fix": "eslint src --ext .ts,.tsx,.js,.jsx --fix",
    "code-quality-check": "npm run lint && npm run type-check",
    "type-check": "tsc --noEmit",
    "test:watch": "jest --watch",
    "test": "jest",
    "test:e2e": "playwright test --project=Chrome --project=Firefox --project=WebKit",
    "test:e2e:chrome": "playwright test --project=Chrome",
    "test:e2e:dev": "playwright test --project=Chrome --headed",
    "test:e2e:report": "playwright show-report",
    "swagger:generate-doc": "npx next-swagger-doc-cli src/next-swagger-doc.json --output swaggerAPI.json",
    "cypress:open": "cypress open --config-file cypress/config/cypress-dev-config.ts",
    "capture-screenshots": "playwright test e2e/tests/capture-screenshots.spec.ts",
    "validate-help-panel": "node scripts/validate-help-panel.js"
  },
  "dependencies": {
    "@axe-core/react": "^4.12.1",
    "@babel/types": "^7.29.7",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^7.0.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@elastic/ecs-winston-format": "^1.5.3",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/server": "^11.11.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/roboto": "^5.2.10",
    "@fontsource/ubuntu": "^5.2.8",
    "@mui/icons-material": "^5.18.0",
    "@mui/lab": "^5.0.0-alpha.177",
    "@mui/material": "^5.18.0",
    "@mui/x-data-grid": "^6.20.4",
    "@mui/x-date-pickers": "^6.20.2",
    "@types/node": "^20.19.43",
    "@types/node-fetch": "^2.6.13",
    "@types/tcp-ping": "^0.1.6",
    "@types/xml2js": "^0.4.14",
    "@xmldom/xmldom": "^0.9.10",
    "axios": "^1.18.1",
    "http-status-codes": "^2.3.0",
    "lodash": "^4.18.1",
    "markdown-it": "^14.3.0",
    "moment": "^2.30.1",
    "next": "^16.2.10",
    "next-api-middleware": "^2.0.1",
    "next-auth": "^4.24.14",
    "next-swagger-doc": "^0.4.1",
    "node-forge": "^1.4.0",
    "prisma": "^4.16.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-to-print": "^2.15.1",
    "saml2-js": "^4.0.4",
    "swagger-ui-react": "^5.32.8",
    "swr": "^2.4.2",
    "uuid": "npm:@izgateway/uuid-cjs@^14.0.7",
    "waait": "^1.0.5",
